{
  "id": "vagrant",
  "label": "Vagrant",
  "version": "1.0",
  "fileExtension": "file",
  "sections": [
    {
      "id": "vm",
      "label": "Virtual Machine",
      "optional": false,
      "repeatable": false,
      "fields": [
        { "id": "box", "label": "Base box", "type": "select", "required": true, "defaultValue": "ubuntu/jammy64", "options": ["ubuntu/jammy64","ubuntu/focal64","ubuntu/bionic64","debian/bullseye64","debian/bookworm64","centos/stream9","centos/7","rockylinux/9","almalinux/9","fedora/38-cloud-base","hashicorp/bionic64","generic/alpine318","bento/amazonlinux-2023"], "help": "Base OS image. All boxes are sourced from Vagrant Cloud." },
        { "id": "box_version", "label": "Box version constraint", "type": "text", "required": false, "placeholder": ">= 0", "help": "Semantic version constraint. Leave blank for latest." },
        { "id": "vm_name", "label": "VM name", "type": "text", "required": true, "defaultValue": "default", "help": "Name shown in VirtualBox/VMware UI and used for vagrant ssh." },
        { "id": "hostname", "label": "Hostname", "type": "text", "required": false, "placeholder": "myserver.local" },
        { "id": "cpus", "label": "CPUs", "type": "select", "required": true, "defaultValue": "2", "options": ["1","2","4","8"] },
        { "id": "memory", "label": "Memory (MB)", "type": "select", "required": true, "defaultValue": "2048", "options": ["512","1024","2048","4096","8192","16384"] }
      ]
    },
    {
      "id": "network_forwarded",
      "label": "Network — Port Forwarding",
      "optional": true,
      "defaultEnabled": false,
      "repeatable": true,
      "maxInstances": 20,
      "fields": [
        { "id": "guest_port", "label": "Guest port", "type": "text", "required": true, "placeholder": "80" },
        { "id": "host_port", "label": "Host port", "type": "text", "required": true, "placeholder": "8080" },
        { "id": "protocol", "label": "Protocol", "type": "select", "required": true, "defaultValue": "tcp", "options": ["tcp","udp"] },
        { "id": "auto_correct", "label": "Auto-correct conflicts", "type": "select", "required": true, "defaultValue": "false", "options": ["false","true"], "help": "If true, Vagrant will pick a different host port if the specified one is taken." },
        { "id": "port_id", "label": "Port ID (optional identifier)", "type": "text", "required": false, "placeholder": "http" }
      ]
    },
    {
      "id": "network_private",
      "label": "Network — Private Network",
      "optional": true,
      "defaultEnabled": false,
      "repeatable": false,
      "fields": [
        { "id": "network_type", "label": "Type", "type": "select", "required": true, "defaultValue": "static", "options": ["static","dhcp"] },
        { "id": "ip_address", "label": "IP address", "type": "text", "required": false, "placeholder": "192.168.56.10", "help": "Required when type = static. Used for host-only networking." },
        { "id": "netmask", "label": "Netmask", "type": "text", "required": false, "placeholder": "255.255.255.0" }
      ]
    },
    {
      "id": "network_public",
      "label": "Network — Public Network (Bridged)",
      "optional": true,
      "defaultEnabled": false,
      "repeatable": false,
      "fields": [
        { "id": "bridge_interface", "label": "Bridge adapter", "type": "text", "required": false, "placeholder": "en0: Wi-Fi", "help": "Leave blank for an interactive prompt on vagrant up." },
        { "id": "use_dhcp_route", "label": "Use DHCP-assigned default route", "type": "select", "required": true, "defaultValue": "false", "options": ["false","true"] }
      ]
    },
    {
      "id": "synced_folder",
      "label": "Synced Folders",
      "optional": true,
      "defaultEnabled": false,
      "repeatable": true,
      "maxInstances": 10,
      "fields": [
        { "id": "host_path", "label": "Host path", "type": "text", "required": true, "placeholder": "." },
        { "id": "guest_path", "label": "Guest path", "type": "text", "required": true, "placeholder": "/vagrant" },
        { "id": "folder_type", "label": "Sync type", "type": "select", "required": true, "defaultValue": "virtualbox", "options": ["virtualbox","nfs","smb","rsync"], "help": "NFS is faster on macOS/Linux. SMB works well on Windows hosts. rsync is one-directional." },
        { "id": "owner", "label": "Owner (user)", "type": "text", "required": false, "placeholder": "vagrant" },
        { "id": "group", "label": "Group", "type": "text", "required": false, "placeholder": "vagrant" },
        { "id": "disabled", "label": "Disabled", "type": "select", "required": true, "defaultValue": "false", "options": ["false","true"] }
      ]
    },
    {
      "id": "provider_virtualbox",
      "label": "Provider — VirtualBox",
      "optional": true,
      "defaultEnabled": false,
      "repeatable": false,
      "fields": [
        { "id": "vb_memory", "label": "Memory override (MB)", "type": "text", "required": false, "placeholder": "2048" },
        { "id": "vb_cpus", "label": "CPU override", "type": "text", "required": false, "placeholder": "2" },
        { "id": "vb_gui", "label": "Show GUI", "type": "select", "required": true, "defaultValue": "false", "options": ["false","true"] },
        { "id": "vb_linked_clone", "label": "Linked clone", "type": "select", "required": true, "defaultValue": "false", "options": ["false","true"], "help": "Linked clones save disk space by sharing base box storage." },
        { "id": "vb_name", "label": "VirtualBox VM name", "type": "text", "required": false, "placeholder": "myproject-vm" },
        { "id": "vb_natdnshostresolver", "label": "NAT DNS host resolver", "type": "select", "required": true, "defaultValue": "on", "options": ["on","off"], "help": "Recommended: on. Fixes DNS resolution issues in NAT networking." }
      ]
    },
    {
      "id": "provider_vmware",
      "label": "Provider — VMware",
      "optional": true,
      "defaultEnabled": false,
      "repeatable": false,
      "fields": [
        { "id": "vmware_memory", "label": "Memory (MB)", "type": "text", "required": false, "placeholder": "2048" },
        { "id": "vmware_cpus", "label": "CPUs", "type": "text", "required": false, "placeholder": "2" },
        { "id": "vmware_gui", "label": "Show GUI", "type": "select", "required": true, "defaultValue": "false", "options": ["false","true"] }
      ]
    },
    {
      "id": "provision_shell",
      "label": "Provisioner — Shell",
      "optional": true,
      "defaultEnabled": false,
      "repeatable": true,
      "maxInstances": 10,
      "fields": [
        { "id": "shell_type", "label": "Script source", "type": "select", "required": true, "defaultValue": "inline", "options": ["inline","path"] },
        { "id": "inline_script", "label": "Inline script", "type": "textarea", "required": false, "placeholder": "#!/bin/bash\napt-get update\napt-get install -y nginx", "help": "Shell commands to execute inline. Used when source = inline." },
        { "id": "script_path", "label": "Script file path", "type": "text", "required": false, "placeholder": "scripts/bootstrap.sh", "help": "Path relative to Vagrantfile. Used when source = path." },
        { "id": "privileged", "label": "Privileged (run as root)", "type": "select", "required": true, "defaultValue": "true", "options": ["true","false"] },
        { "id": "shell_env", "label": "Environment variables", "type": "textarea", "required": false, "placeholder": "APP_ENV=production\nDB_HOST=localhost", "help": "KEY=VALUE format, one per line." }
      ]
    },
    {
      "id": "provision_ansible",
      "label": "Provisioner — Ansible",
      "optional": true,
      "defaultEnabled": false,
      "repeatable": false,
      "fields": [
        { "id": "playbook_path", "label": "Playbook path", "type": "text", "required": true, "defaultValue": "provisioning/playbook.yml" },
        { "id": "inventory_path", "label": "Inventory path", "type": "text", "required": false, "placeholder": "provisioning/inventory" },
        { "id": "ansible_become", "label": "Become (sudo)", "type": "select", "required": true, "defaultValue": "false", "options": ["false","true"] },
        { "id": "ansible_verbose", "label": "Verbose output", "type": "select", "required": true, "defaultValue": "false", "options": ["false","true"] },
        { "id": "galaxy_role_file", "label": "Galaxy requirements file", "type": "text", "required": false, "placeholder": "provisioning/requirements.yml" },
        { "id": "extra_vars", "label": "Extra variables", "type": "textarea", "required": false, "placeholder": "app_env: production\napp_port: 8080", "help": "YAML key: value format, one per line." }
      ]
    },
    {
      "id": "provision_file",
      "label": "Provisioner — File Upload",
      "optional": true,
      "defaultEnabled": false,
      "repeatable": true,
      "maxInstances": 10,
      "fields": [
        { "id": "file_source", "label": "Source (host)", "type": "text", "required": true, "placeholder": "config/app.conf" },
        { "id": "file_destination", "label": "Destination (guest)", "type": "text", "required": true, "placeholder": "/etc/app/app.conf" }
      ]
    },
    {
      "id": "provision_docker",
      "label": "Provisioner — Docker",
      "optional": true,
      "defaultEnabled": false,
      "repeatable": false,
      "fields": [
        { "id": "docker_install", "label": "Install Docker engine", "type": "select", "required": true, "defaultValue": "true", "options": ["true","false"] },
        { "id": "docker_images", "label": "Images to pull", "type": "text", "required": false, "placeholder": "nginx:latest,redis:7-alpine", "help": "Comma-separated image names." }
      ]
    },
    {
      "id": "multi_machine",
      "label": "Multi-Machine",
      "optional": true,
      "defaultEnabled": false,
      "repeatable": true,
      "maxInstances": 10,
      "fields": [
        { "id": "machine_name", "label": "Machine name", "type": "text", "required": true, "placeholder": "web" },
        { "id": "machine_box", "label": "Box", "type": "text", "required": true, "placeholder": "ubuntu/jammy64" },
        { "id": "machine_cpus", "label": "CPUs", "type": "select", "required": true, "defaultValue": "1", "options": ["1","2","4","8"] },
        { "id": "machine_memory", "label": "Memory (MB)", "type": "select", "required": true, "defaultValue": "1024", "options": ["512","1024","2048","4096","8192"] },
        { "id": "machine_ip", "label": "Private IP", "type": "text", "required": false, "placeholder": "192.168.56.11" },
        { "id": "machine_hostname", "label": "Hostname", "type": "text", "required": false, "placeholder": "web.local" }
      ]
    },
    {
      "id": "ssh",
      "label": "SSH Configuration",
      "optional": true,
      "defaultEnabled": false,
      "repeatable": false,
      "fields": [
        { "id": "ssh_username", "label": "SSH username", "type": "text", "required": true, "defaultValue": "vagrant" },
        { "id": "ssh_private_key_path", "label": "Private key path", "type": "text", "required": false, "placeholder": "~/.ssh/id_rsa" },
        { "id": "ssh_forward_agent", "label": "Forward SSH agent", "type": "select", "required": true, "defaultValue": "false", "options": ["false","true"] },
        { "id": "ssh_insert_key", "label": "Insert generated key", "type": "select", "required": true, "defaultValue": "true", "options": ["true","false"], "help": "Vagrant generates and inserts a new key pair on first boot. Recommended: true." },
        { "id": "ssh_port", "label": "SSH port", "type": "text", "required": false, "defaultValue": "22" }
      ]
    }
  ]
}
