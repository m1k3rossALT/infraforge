<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    <!--
        Add suppression entries here when the OWASP check flags a false positive.

        Example — suppress a specific CVE for a specific file:
        <suppress>
            <notes>
                CVE-YYYY-XXXXX is a false positive. The vulnerable code path is not used
                in InfraForge because [reason]. Reviewed on YYYY-MM-DD by [name].
                Revisit when [library] releases a fix.
            </notes>
            <filePath regex="true">.*some-library-.*\.jar</filePath>
            <cve>CVE-YYYY-XXXXX</cve>
        </suppress>

        Always document WHY a suppression exists and WHEN to revisit it.
        Never suppress without a reason.
    -->
</suppressions>