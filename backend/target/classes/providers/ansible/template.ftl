<#-- Ansible Playbook — generated by InfraForge -->
<#assign s = sections>
<#assign pb = s.playbook.instances[0]>
---
- name: ${pb.playbook_name!"My Playbook"}
  hosts: ${pb.hosts!"all"}
  gather_facts: ${pb.gather_facts!"true"}
  become: ${pb.become!"false"}
<#if pb.become == "true" && pb.become_user?has_content>
  become_user: ${pb.become_user}
</#if>
  connection: ${pb.connection!"ssh"}
  strategy: ${pb.strategy!"linear"}
<#if pb.any_errors_fatal == "true">
  any_errors_fatal: true
</#if>
<#if pb.max_fail_percentage?has_content>
  max_fail_percentage: ${pb.max_fail_percentage}
</#if>
<#-- ─── Variables ──────────────────────────────────────────────────── -->
<#if s.variables?? && s.variables.enabled && s.variables.instances?has_content>

  vars:
<#list s.variables.instances as v>
<#if v.var_name?has_content>
    ${v.var_name}: ${v.var_value!""}
</#if>
</#list>
</#if>
<#-- ─── Roles ─────────────────────────────────────────────────────── -->
<#if s.roles?? && s.roles.enabled && s.roles.instances?has_content>

  roles:
<#list s.roles.instances as role>
<#if role.role_name?has_content>
    - role: ${role.role_name}
<#if role.role_vars?has_content>
      vars:
<#list role.role_vars?split("\n") as line>
<#if line?trim?has_content>
        ${line?trim}
</#if>
</#list>
</#if>
<#if role.when_condition?has_content>
      when: ${role.when_condition}
</#if>
</#if>
</#list>
</#if>
<#-- ─── Tasks ─────────────────────────────────────────────────────── -->
<#assign hasTasks = (s.tasks_package?? && s.tasks_package.enabled) || (s.tasks_service?? && s.tasks_service.enabled) || (s.tasks_file?? && s.tasks_file.enabled) || (s.tasks_command?? && s.tasks_command.enabled) || (s.tasks_user?? && s.tasks_user.enabled) || (s.tasks_git?? && s.tasks_git.enabled) || (s.tasks_template?? && s.tasks_template.enabled) || (s.tasks_cron?? && s.tasks_cron.enabled)>
<#if hasTasks>

  tasks:
<#-- Package tasks -->
<#if s.tasks_package?? && s.tasks_package.enabled>
<#list s.tasks_package.instances as task>
<#if task.task_name?has_content>

    - name: "${task.task_name}"
      ansible.builtin.package:
        name: <#if task.packages?contains(",")>[<#list task.packages?split(",") as p>"${p?trim}"<#sep>, </#sep></#list>]<#else>${task.packages!""}</#if>
        state: ${task.package_state!"present"}
<#if task.update_cache == "true">
        update_cache: true
</#if>
<#if task.when_condition?has_content>
      when: ${task.when_condition}
</#if>
<#if task.notify?has_content>
      notify: "${task.notify}"
</#if>
</#if>
</#list>
</#if>
<#-- Service tasks -->
<#if s.tasks_service?? && s.tasks_service.enabled>
<#list s.tasks_service.instances as task>
<#if task.task_name?has_content>

    - name: "${task.task_name}"
      ansible.builtin.service:
        name: ${task.service_name!""}
        state: ${task.service_state!"started"}
        enabled: ${task.service_enabled!"true"}
<#if task.when_condition?has_content>
      when: ${task.when_condition}
</#if>
</#if>
</#list>
</#if>
<#-- File tasks -->
<#if s.tasks_file?? && s.tasks_file.enabled>
<#list s.tasks_file.instances as task>
<#if task.task_name?has_content>

    - name: "${task.task_name}"
      ansible.builtin.file:
        path: ${task.file_path!""}
        state: ${task.file_state!"file"}
<#if task.file_mode?has_content>
        mode: "${task.file_mode}"
</#if>
<#if task.file_owner?has_content>
        owner: ${task.file_owner}
</#if>
<#if task.file_group?has_content>
        group: ${task.file_group}
</#if>
<#if task.when_condition?has_content>
      when: ${task.when_condition}
</#if>
</#if>
</#list>
</#if>
<#-- Command tasks -->
<#if s.tasks_command?? && s.tasks_command.enabled>
<#list s.tasks_command.instances as task>
<#if task.task_name?has_content>

    - name: "${task.task_name}"
      ansible.builtin.${task.command_module!"command"}:
        cmd: ${task.command!""}
<#if task.command_chdir?has_content>
        chdir: ${task.command_chdir}
</#if>
<#if task.creates?has_content>
        creates: ${task.creates}
</#if>
<#if task.register_var?has_content>
      register: ${task.register_var}
</#if>
<#if task.when_condition?has_content>
      when: ${task.when_condition}
</#if>
<#if task.notify?has_content>
      notify: "${task.notify}"
</#if>
</#if>
</#list>
</#if>
<#-- User tasks -->
<#if s.tasks_user?? && s.tasks_user.enabled>
<#list s.tasks_user.instances as task>
<#if task.task_name?has_content>

    - name: "${task.task_name}"
      ansible.builtin.user:
        name: ${task.username!""}
        state: ${task.user_state!"present"}
<#if task.user_groups?has_content>
        groups: ${task.user_groups}
</#if>
<#if task.user_shell?has_content>
        shell: ${task.user_shell}
</#if>
<#if task.user_home?has_content>
        home: ${task.user_home}
</#if>
        create_home: ${task.create_home!"true"}
        system: ${task.system_user!"false"}
<#if task.when_condition?has_content>
      when: ${task.when_condition}
</#if>
</#if>
</#list>
</#if>
<#-- Git tasks -->
<#if s.tasks_git?? && s.tasks_git.enabled>
<#list s.tasks_git.instances as task>
<#if task.task_name?has_content>

    - name: "${task.task_name}"
      ansible.builtin.git:
        repo: ${task.git_repo!""}
        dest: ${task.git_dest!""}
        version: ${task.git_version!"HEAD"}
<#if task.git_depth?has_content>
        depth: ${task.git_depth}
</#if>
        force: ${task.git_force!"false"}
<#if task.when_condition?has_content>
      when: ${task.when_condition}
</#if>
</#if>
</#list>
</#if>
<#-- Template tasks -->
<#if s.tasks_template?? && s.tasks_template.enabled>
<#list s.tasks_template.instances as task>
<#if task.task_name?has_content>

    - name: "${task.task_name}"
      ansible.builtin.template:
        src: ${task.template_src!""}
        dest: ${task.template_dest!""}
<#if task.template_mode?has_content>
        mode: "${task.template_mode}"
</#if>
<#if task.template_owner?has_content>
        owner: ${task.template_owner}
</#if>
<#if task.notify?has_content>
      notify: "${task.notify}"
</#if>
<#if task.when_condition?has_content>
      when: ${task.when_condition}
</#if>
</#if>
</#list>
</#if>
<#-- Cron tasks -->
<#if s.tasks_cron?? && s.tasks_cron.enabled>
<#list s.tasks_cron.instances as task>
<#if task.task_name?has_content>

    - name: "${task.task_name}"
      ansible.builtin.cron:
        name: "${task.cron_name!task.task_name}"
        minute: "${task.cron_minute!"0"}"
        hour: "${task.cron_hour!"*"}"
        day: "${task.cron_day!"*"}"
        month: "${task.cron_month!"*"}"
        weekday: "${task.cron_weekday!"*"}"
        job: "${task.cron_job!""}"
        user: ${task.cron_user!"root"}
        state: ${task.cron_state!"present"}
</#if>
</#list>
</#if>
</#if>
<#-- ─── Handlers ───────────────────────────────────────────────────── -->
<#if s.handlers?? && s.handlers.enabled && s.handlers.instances?has_content>

  handlers:
<#list s.handlers.instances as handler>
<#if handler.handler_name?has_content>

    - name: "${handler.handler_name}"
      ansible.builtin.${handler.handler_module!"service"}:
        name: ${handler.handler_service!""}
        state: ${handler.handler_state!"restarted"}
</#if>
</#list>
</#if>
