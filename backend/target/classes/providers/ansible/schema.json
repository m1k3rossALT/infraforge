{
  "id": "ansible",
  "label": "Ansible",
  "version": "1.0",
  "fileExtension": ".yml",
  "sections": [
    {
      "id": "playbook",
      "label": "Playbook",
      "optional": false,
      "repeatable": false,
      "fields": [
        { "id": "playbook_name", "label": "Playbook name", "type": "text", "required": true, "defaultValue": "My Playbook" },
        { "id": "hosts", "label": "Target hosts", "type": "text", "required": true, "defaultValue": "all", "help": "Host pattern from your inventory. Use 'all', a group name (e.g. webservers), or a specific host." },
        { "id": "gather_facts", "label": "Gather facts", "type": "select", "required": true, "defaultValue": "true", "options": ["true","false"], "help": "Set to false to skip gathering host facts and speed up execution." },
        { "id": "become", "label": "Privilege escalation (become)", "type": "select", "required": true, "defaultValue": "false", "options": ["false","true"] },
        { "id": "become_user", "label": "Become user", "type": "text", "required": false, "defaultValue": "root", "help": "User to escalate to. Only used when become = true." },
        { "id": "connection", "label": "Connection type", "type": "select", "required": true, "defaultValue": "ssh", "options": ["ssh","local","docker","winrm"] },
        { "id": "strategy", "label": "Execution strategy", "type": "select", "required": true, "defaultValue": "linear", "options": ["linear","free","debug"], "help": "'free' lets each host run tasks as fast as possible without waiting for others." },
        { "id": "any_errors_fatal", "label": "Any errors fatal", "type": "select", "required": true, "defaultValue": "false", "options": ["false","true"], "help": "If true, any failed task on any host stops the entire play." },
        { "id": "max_fail_percentage", "label": "Max fail percentage", "type": "text", "required": false, "placeholder": "0", "help": "Abort play if this percentage of hosts fail. Leave blank to ignore." }
      ]
    },
    {
      "id": "variables",
      "label": "Variables",
      "optional": true,
      "defaultEnabled": false,
      "repeatable": true,
      "maxInstances": 50,
      "fields": [
        { "id": "var_name", "label": "Variable name", "type": "text", "required": true, "placeholder": "app_port" },
        { "id": "var_value", "label": "Value", "type": "text", "required": true, "placeholder": "8080" }
      ]
    },
    {
      "id": "tasks_package",
      "label": "Tasks — Package Management",
      "optional": true,
      "defaultEnabled": false,
      "repeatable": true,
      "maxInstances": 30,
      "fields": [
        { "id": "task_name", "label": "Task name", "type": "text", "required": true, "placeholder": "Install nginx" },
        { "id": "package_manager", "label": "Package manager", "type": "select", "required": true, "defaultValue": "apt", "options": ["apt","yum","dnf","pacman","zypper","pip","npm","gem"] },
        { "id": "package_name", "label": "Package name(s)", "type": "text", "required": true, "placeholder": "nginx", "help": "Single package name. For multiple packages, add a separate task per package." },
        { "id": "package_state", "label": "State", "type": "select", "required": true, "defaultValue": "present", "options": ["present","absent","latest","build-dep"] },
        { "id": "update_cache", "label": "Update cache first", "type": "select", "required": true, "defaultValue": "false", "options": ["false","true"] }
      ]
    },
    {
      "id": "tasks_service",
      "label": "Tasks — Service Management",
      "optional": true,
      "defaultEnabled": false,
      "repeatable": true,
      "maxInstances": 20,
      "fields": [
        { "id": "task_name", "label": "Task name", "type": "text", "required": true, "placeholder": "Start nginx" },
        { "id": "service_name", "label": "Service name", "type": "text", "required": true, "placeholder": "nginx" },
        { "id": "service_state", "label": "State", "type": "select", "required": true, "defaultValue": "started", "options": ["started","stopped","restarted","reloaded"] },
        { "id": "service_enabled", "label": "Enabled on boot", "type": "select", "required": true, "defaultValue": "true", "options": ["true","false"] },
        { "id": "daemon_reload", "label": "Daemon reload (systemd)", "type": "select", "required": true, "defaultValue": "false", "options": ["false","true"] }
      ]
    },
    {
      "id": "tasks_file",
      "label": "Tasks — File Operations",
      "optional": true,
      "defaultEnabled": false,
      "repeatable": true,
      "maxInstances": 30,
      "fields": [
        { "id": "task_name", "label": "Task name", "type": "text", "required": true, "placeholder": "Copy config file" },
        { "id": "file_module", "label": "Module", "type": "select", "required": true, "defaultValue": "copy", "options": ["copy","template","file","lineinfile","blockinfile","fetch","replace","stat"] },
        { "id": "src", "label": "Source path", "type": "text", "required": false, "placeholder": "files/nginx.conf" },
        { "id": "dest", "label": "Destination path", "type": "text", "required": true, "placeholder": "/etc/nginx/nginx.conf" },
        { "id": "owner", "label": "Owner", "type": "text", "required": false, "placeholder": "root" },
        { "id": "group", "label": "Group", "type": "text", "required": false, "placeholder": "root" },
        { "id": "mode", "label": "Mode", "type": "text", "required": false, "placeholder": "0644" },
        { "id": "file_state", "label": "State (file module only)", "type": "select", "required": false, "defaultValue": "present", "options": ["present","absent","directory","touch","link","hard"] },
        { "id": "recurse", "label": "Recurse (directory)", "type": "select", "required": false, "defaultValue": "false", "options": ["false","true"] }
      ]
    },
    {
      "id": "tasks_command",
      "label": "Tasks — Commands & Scripts",
      "optional": true,
      "defaultEnabled": false,
      "repeatable": true,
      "maxInstances": 30,
      "fields": [
        { "id": "task_name", "label": "Task name", "type": "text", "required": true, "placeholder": "Run database migration" },
        { "id": "command_module", "label": "Module", "type": "select", "required": true, "defaultValue": "command", "options": ["command","shell","raw","script"], "help": "'command' is safer (no shell expansion). Use 'shell' for pipes, redirects, or environment expansion." },
        { "id": "command", "label": "Command", "type": "textarea", "required": true, "placeholder": "/usr/bin/python manage.py migrate" },
        { "id": "chdir", "label": "Working directory (chdir)", "type": "text", "required": false, "placeholder": "/var/app" },
        { "id": "creates", "label": "Creates (idempotency check)", "type": "text", "required": false, "help": "If this path exists, the task is skipped." },
        { "id": "register_var", "label": "Register output as variable", "type": "text", "required": false, "placeholder": "migration_result" },
        { "id": "ignore_errors", "label": "Ignore errors", "type": "select", "required": false, "defaultValue": "false", "options": ["false","true"] }
      ]
    },
    {
      "id": "tasks_user",
      "label": "Tasks — User Management",
      "optional": true,
      "defaultEnabled": false,
      "repeatable": true,
      "maxInstances": 20,
      "fields": [
        { "id": "task_name", "label": "Task name", "type": "text", "required": true, "placeholder": "Create deploy user" },
        { "id": "username", "label": "Username", "type": "text", "required": true, "placeholder": "deploy" },
        { "id": "user_state", "label": "State", "type": "select", "required": true, "defaultValue": "present", "options": ["present","absent"] },
        { "id": "groups", "label": "Groups (comma-separated)", "type": "text", "required": false, "placeholder": "sudo,docker" },
        { "id": "shell", "label": "Login shell", "type": "text", "required": false, "defaultValue": "/bin/bash" },
        { "id": "home_dir", "label": "Home directory", "type": "text", "required": false, "placeholder": "/home/deploy" },
        { "id": "create_home", "label": "Create home directory", "type": "select", "required": true, "defaultValue": "true", "options": ["true","false"] },
        { "id": "password_lock", "label": "Lock password (SSH-only)", "type": "select", "required": true, "defaultValue": "true", "options": ["true","false"] }
      ]
    },
    {
      "id": "tasks_git",
      "label": "Tasks — Git",
      "optional": true,
      "defaultEnabled": false,
      "repeatable": true,
      "maxInstances": 10,
      "fields": [
        { "id": "task_name", "label": "Task name", "type": "text", "required": true, "placeholder": "Clone application repo" },
        { "id": "repo_url", "label": "Repository URL", "type": "text", "required": true, "placeholder": "https://github.com/org/repo.git" },
        { "id": "dest", "label": "Destination path", "type": "text", "required": true, "placeholder": "/var/app" },
        { "id": "version", "label": "Branch / tag / commit", "type": "text", "required": true, "defaultValue": "main" },
        { "id": "force_update", "label": "Force (overwrite local changes)", "type": "select", "required": true, "defaultValue": "false", "options": ["false","true"] },
        { "id": "depth", "label": "Clone depth (0 = full clone)", "type": "text", "required": false, "defaultValue": "0" },
        { "id": "accept_hostkey", "label": "Accept host key", "type": "select", "required": true, "defaultValue": "true", "options": ["true","false"] }
      ]
    },
    {
      "id": "tasks_template",
      "label": "Tasks — Jinja2 Templates",
      "optional": true,
      "defaultEnabled": false,
      "repeatable": true,
      "maxInstances": 20,
      "fields": [
        { "id": "task_name", "label": "Task name", "type": "text", "required": true, "placeholder": "Deploy app config" },
        { "id": "src_template", "label": "Template source path", "type": "text", "required": true, "placeholder": "templates/app.conf.j2", "help": "Relative path to the .j2 template file in your role or playbook directory." },
        { "id": "dest_path", "label": "Destination path", "type": "text", "required": true, "placeholder": "/etc/app/app.conf" },
        { "id": "owner", "label": "Owner", "type": "text", "required": false, "placeholder": "root" },
        { "id": "group", "label": "Group", "type": "text", "required": false, "placeholder": "root" },
        { "id": "mode", "label": "Mode", "type": "text", "required": false, "placeholder": "0640" },
        { "id": "backup", "label": "Backup existing file", "type": "select", "required": false, "defaultValue": "false", "options": ["false","true"] }
      ]
    },
    {
      "id": "tasks_cron",
      "label": "Tasks — Cron Jobs",
      "optional": true,
      "defaultEnabled": false,
      "repeatable": true,
      "maxInstances": 10,
      "fields": [
        { "id": "task_name", "label": "Task name", "type": "text", "required": true, "placeholder": "Schedule daily backup" },
        { "id": "cron_name", "label": "Cron job name", "type": "text", "required": true, "placeholder": "daily_backup", "help": "Unique identifier for this cron job. Used to manage idempotency." },
        { "id": "minute", "label": "Minute", "type": "text", "required": true, "defaultValue": "0", "placeholder": "0" },
        { "id": "hour", "label": "Hour", "type": "text", "required": true, "defaultValue": "2", "placeholder": "2" },
        { "id": "day", "label": "Day of month", "type": "text", "required": true, "defaultValue": "*" },
        { "id": "month", "label": "Month", "type": "text", "required": true, "defaultValue": "*" },
        { "id": "weekday", "label": "Weekday (0=Sun)", "type": "text", "required": true, "defaultValue": "*" },
        { "id": "cron_job", "label": "Command", "type": "text", "required": true, "placeholder": "/usr/local/bin/backup.sh >> /var/log/backup.log 2>&1" },
        { "id": "cron_user", "label": "Run as user", "type": "text", "required": true, "defaultValue": "root" },
        { "id": "cron_state", "label": "State", "type": "select", "required": true, "defaultValue": "present", "options": ["present","absent"] }
      ]
    },
    {
      "id": "handlers",
      "label": "Handlers",
      "optional": true,
      "defaultEnabled": false,
      "repeatable": true,
      "maxInstances": 20,
      "fields": [
        { "id": "handler_name", "label": "Handler name", "type": "text", "required": true, "placeholder": "Restart nginx", "help": "Tasks notify handlers by this name using 'notify: Handler name'." },
        { "id": "service_name", "label": "Service name", "type": "text", "required": true, "placeholder": "nginx" },
        { "id": "handler_state", "label": "State", "type": "select", "required": true, "defaultValue": "restarted", "options": ["restarted","reloaded","stopped","started"] }
      ]
    },
    {
      "id": "roles",
      "label": "Roles",
      "optional": true,
      "defaultEnabled": false,
      "repeatable": true,
      "maxInstances": 20,
      "fields": [
        { "id": "role_name", "label": "Role name", "type": "text", "required": true, "placeholder": "geerlingguy.nginx", "help": "Local role name or Galaxy role in the format author.role_name." },
        { "id": "role_become", "label": "Become", "type": "select", "required": true, "defaultValue": "false", "options": ["false","true"] },
        { "id": "role_vars", "label": "Role variables", "type": "textarea", "required": false, "placeholder": "nginx_listen_port: 80\nnginx_worker_processes: auto", "help": "YAML key: value format, one per line." }
      ]
    }
  ]
}
